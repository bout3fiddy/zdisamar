    "./zig-out/bin/zdisamar --config data/examples/legacy_config.in"
  ],
  "required_packages": [
    {
      "name": "disamar_standard",
      "version": "0.1.0"
    },
    {
      "name": "builtin_exporters",
      "version": "0.1.0"
    },
    {
      "name": "mission_s5p",
      "version": "0.1.0"
    }
  ],
  "required_plugin_versions": [
