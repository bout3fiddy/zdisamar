{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zdisamar.dev/schemas/result.schema.json",
  "title": "zdisamar result",
  "type": "object",
  "required": ["status", "plan_id", "scene_id", "provenance"],
  "properties": {
    "status": { "type": "string" },
    "plan_id": { "type": "integer", "minimum": 0 },
    "scene_id": { "type": "string" },
    "diagnostics": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "measurement_space": {
      "type": "object",
      "properties": {
        "sample_count": { "type": "integer", "minimum": 0 },
        "wavelength_start_nm": { "type": "number" },
        "wavelength_end_nm": { "type": "number" },
        "mean_radiance": { "type": "number" },
        "mean_irradiance": { "type": "number" },
        "mean_reflectance": { "type": "number" },
        "mean_noise_sigma": { "type": "number" },
        "mean_jacobian": {
          "anyOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "artifact_uri", "plugin_id", "media_type"],
        "properties": {
          "format": {
            "type": "string",
            "enum": ["netcdf_cf", "zarr"]
          },
          "artifact_uri": { "type": "string" },
          "plugin_id": { "type": "string" },
          "media_type": { "type": "string" },
          "dataset_name": { "type": "string" },
          "includes_provenance": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "required": ["model_family", "solver_route", "transport_family", "derivative_mode", "numerical_mode"],
      "properties": {
        "model_family": { "type": "string" },
        "solver_route": { "type": "string" },
        "transport_family": { "type": "string" },
        "derivative_mode": { "type": "string" },
        "numerical_mode": { "type": "string" },
        "plugin_versions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dataset_hashes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "native_capability_slots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "native_entry_symbols": {
          "type": "array",
          "items": { "type": "string" }
        },
        "native_library_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
