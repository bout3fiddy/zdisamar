{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zdisamar.dev/schemas/request.schema.json",
  "title": "zdisamar request",
  "type": "object",
  "required": ["scene"],
  "properties": {
    "scene": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "spectral_grid": {
          "type": "object",
          "properties": {
            "start_nm": { "type": "number" },
            "end_nm": { "type": "number" },
            "sample_count": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "requested_products": {
      "type": "array",
      "items": { "type": "string" }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "provenance": { "type": "boolean" },
        "jacobians": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "destination_uri"],
        "properties": {
          "format": {
            "type": "string",
            "enum": ["netcdf_cf", "zarr"]
          },
          "destination_uri": { "type": "string" },
          "dataset_name": { "type": "string" },
          "include_provenance": { "type": "boolean" },
          "compression": {
            "type": "object",
            "properties": {
              "codec": {
                "type": "string",
                "enum": ["none", "zstd", "gzip"]
              },
              "level": {
                "type": "integer",
                "minimum": 0,
                "maximum": 22
              }
            },
            "additionalProperties": false
          },
          "chunking": {
            "type": "object",
            "properties": {
              "spectra": { "type": "integer", "minimum": 1 },
              "layers": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
